---
interface Badge {
  icon: string;
  text: string;
}

interface CtaButton {
  label: string;
  href: string;
}

interface Props {
  headingLine1: string;
  headingHighlight: string;
  headingLine3: string;
  subtext: string;
  primaryCta: CtaButton;
  secondaryCta: CtaButton;
  badges: Badge[];
}

const {
  headingLine1,
  headingHighlight,
  headingLine3,
  subtext,
  primaryCta,
  secondaryCta,
  badges,
} = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <h1 class="hero__heading">
        <span class="hero__heading-line">{headingLine1}</span>
        <span class="hero__heading-highlight">{headingHighlight}</span>
        <span class="hero__heading-line">{headingLine3}</span>
      </h1>
      <p class="hero__subtext">{subtext}</p>
      <div class="hero__ctas">
        <a href={primaryCta.href} class="btn btn--primary">{primaryCta.label}</a>
        <a href={secondaryCta.href} class="btn btn--ghost">{secondaryCta.label} →</a>
      </div>
      <div class="hero__badges">
        {badges.map((badge) => (
          <span class="badge">
            <span class="badge__icon">{badge.icon}</span>
            <span class="badge__text">{badge.text}</span>
          </span>
        ))}
      </div>
    </div>
    <div class="hero__visual">
      <div class="hero__image-wrap">
        <img
          src="/images/hero-student.png"
          alt="BTEC student presenting assignment work at college"
          width="600"
          height="480"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          class="hero__image"
        />
        <span class="hero__uk-badge">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 30" width="48" height="24" aria-label="UK flag" role="img">
            <clipPath id="uk-a"><path d="M0 0v30h60V0z"/></clipPath>
            <clipPath id="uk-b"><path d="M30 15h30v15zM30 15v15H0zM30 15H0V0zM30 15V0h30z"/></clipPath>
            <g clip-path="url(#uk-a)">
              <path d="M0 0v30h60V0z" fill="#012169"/>
              <path d="M0 0l60 30m0-30L0 30" stroke="#fff" stroke-width="6"/>
              <path d="M0 0l60 30m0-30L0 30" stroke="#C8102E" stroke-width="4" clip-path="url(#uk-b)"/>
              <path d="M30 0v30M0 15h60" stroke="#fff" stroke-width="10"/>
              <path d="M30 0v30M0 15h60" stroke="#C8102E" stroke-width="6"/>
            </g>
          </svg>
          UK-Based BTEC Experts
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--color-bg-white);
    padding: 5rem 0 4rem;
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero__heading {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.12;
    color: var(--color-primary);
    display: flex;
    flex-direction: column;
    gap: 0.05em;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .hero__heading-line {
    display: block;
  }

  .hero__heading-highlight {
    display: block;
    color: var(--color-accent);
  }

  .hero__subtext {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 520px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2.5rem;
    align-items: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2rem;
    border-radius: 0.375rem;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s;
    border: 2px solid transparent;
    white-space: nowrap;
  }

  .btn--primary {
    background-color: var(--color-accent);
    color: var(--color-white);
    border-color: var(--color-accent);
  }

  .btn--primary:hover {
    background-color: var(--color-accent-dark);
    border-color: var(--color-accent-dark);
  }

  .btn--ghost {
    background-color: transparent;
    color: var(--color-primary);
    border-color: var(--color-border-light);
    font-weight: 500;
  }

  .btn--ghost:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background-color: var(--color-accent-light);
    color: var(--color-primary);
    padding: 0.375rem 0.875rem;
    border-radius: 2rem;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .badge__icon {
    color: var(--color-accent-dark);
    font-weight: 800;
  }

  /* Visual / image right column */
  .hero__visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__image-wrap {
    position: relative;
    width: 100%;
  }

  .hero__image {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    box-shadow: 0 12px 48px rgba(27, 43, 75, 0.18);
    display: block;
    object-fit: cover;
  }

  .hero__uk-badge {
    position: absolute;
    bottom: 1.25rem;
    right: 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    background: #fff;
    border: 1.5px solid rgba(1, 33, 105, 0.15);
    border-radius: 2rem;
    padding: 0.6rem 1.25rem 0.6rem 0.75rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary);
    box-shadow: 0 4px 20px rgba(27, 43, 75, 0.18);
    white-space: nowrap;
  }

  .hero__uk-badge svg {
    border-radius: 3px;
    flex-shrink: 0;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero__visual {
      order: -1;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 3rem 0 2.5rem;
    }

    .hero__ctas {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
